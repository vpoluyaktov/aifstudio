# ─────────────────────────────────────────────────────────────────────────────
# AIFStudio — environment configuration template
#
# Copy this file to `.env` (which is gitignored) and edit the values:
#
#     cp .env.example .env
#     $EDITOR .env
#     docker compose up -d --build
#
# `docker-compose.yml` references `env_file: .env`, so Docker Compose FAILS
# to start if `.env` is missing. There is no fallback.
#
# Lines marked [REQUIRED] must be set or the relevant feature is disabled.
# Lines marked [OPTIONAL] have sane defaults; override only when tuning.
# Every variable here must stay in sync with `service/internal/config/config.go`.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Required for AI authoring ───────────────────────────────────────────────
# [REQUIRED for AI features] OpenAI API key. Empty/unset disables every
# `/api/projects/{id}/ai/*` endpoint with 503 ai_disabled. The rest of the app
# (play, history, projects, builds) works without it.
OPENAI_API_KEY=

# ─── Recommended overrides ───────────────────────────────────────────────────
# [OPTIONAL] Environment label, surfaced in /health and the UI banner.
# Suggested: "local" for dev, "production" for the live host.
ENVIRONMENT=production

# [OPTIONAL] Application version, surfaced in /health and the footer.
# In CI this is set to the Docker Hub image tag; override locally if you care.
APP_VERSION=dev

# [OPTIONAL] HTTP listen port inside the container. The host-side mapping is
# in docker-compose.yml. Change only if you need a different internal port.
PORT=8080

# ─── Storage paths (durable; defaults match the Compose volume mounts) ───────
# [OPTIONAL] SQLite database file. Mounted from host ./data/db.
DB_PATH=/app/data/db/aifstudio.db

# [OPTIONAL] Root of local blob storage (sessions/, builds/, projects/).
# Mounted from host ./data/storage.
STORAGE_PATH=/app/data/storage

# ─── Auth / sessions ─────────────────────────────────────────────────────────
# [OPTIONAL] Session cookie max-age and sessions.expires_at offset.
# Default 720h = 30 days. Format: Go duration (e.g. "168h" = 7 d, "8760h" = 1 y).
SESSION_MAX_AGE=720h

# ─── OpenAI tunables ─────────────────────────────────────────────────────────
# [OPTIONAL] Model name passed to the OpenAI API.
OPENAI_MODEL=gpt-5.2

# [OPTIONAL] OpenAI base URL. Override only when proxying through a gateway.
OPENAI_BASE_URL=https://api.openai.com/v1

# [OPTIONAL] Total streaming timeout for one AI turn.
OPENAI_TIMEOUT=300s

# [OPTIONAL] Hard cap on AI turns recorded per project.
AI_MAX_TURNS_PER_PROJECT=200

# [OPTIONAL] Per-user AI rate limit (token bucket).
AI_RATE_LIMIT_PER_USER_QPS=0.2
AI_RATE_LIMIT_PER_USER_BURST=3

# [OPTIONAL] Caps on AI input/output sizes, in characters.
AI_MAX_DESCRIPTION_CHARS=2000
AI_MAX_MESSAGE_CHARS=16000

# ─── IFDB client ─────────────────────────────────────────────────────────────
# [OPTIONAL] Override only for tests pointing at a fixture server.
IFDB_BASE_URL=https://ifdb.org

# [OPTIONAL] User-Agent the AIFStudio backend sends to IFDB. Be a good citizen
# and include a contact address in production.
IFDB_USER_AGENT=AIFStudio/0.1 (contact: vpoluyaktov@gmail.com)

# [OPTIONAL] How long an IFDB lookup stays warm in memory + SQLite cache.
IFDB_CACHE_TTL=10m

# [OPTIONAL] Global token-bucket rate limit on outbound IFDB requests.
IFDB_RATE_LIMIT_QPS=5
IFDB_RATE_LIMIT_BURST=10

# [OPTIONAL] Per-IP token-bucket rate limit on inbound IFDB-proxy requests.
IFDB_RATE_LIMIT_PER_IP_QPS=1
IFDB_RATE_LIMIT_PER_IP_BURST=3

# ─── Run lifecycle ───────────────────────────────────────────────────────────
# [OPTIONAL] Hard cap on a single live interpreter session (since startedAt).
RUN_SESSION_MAX=30m

# [OPTIONAL] Idle-sweep threshold (since lastCommandAt). Idle runs are
# auto-saved and suspended.
RUN_IDLE_TIMEOUT=10m

# [OPTIONAL] How long a run can sit in `pending` before the abandoned-pending
# sweeper deletes it.
ABANDONED_PENDING_TTL=1h
ABANDONED_SWEEP_INTERVAL=15m

# [OPTIONAL] Default page size for GET /api/runs/by-user.
HISTORY_DEFAULT_LIMIT=20

# ─── Save / restore protocol (advanced; rarely changed) ──────────────────────
# [OPTIONAL] Stdout silence (ms) treated as "interpreter is at a stable prompt".
SAVE_QUIESCENCE_MS=200

# [OPTIONAL] Inline-save wait budget (ms).
SAVE_TIMEOUT_MS=1000

# [OPTIONAL] Restore-completion budget (ms).
RESTORE_TIMEOUT_MS=2000

# ─── Limits and graceful shutdown ────────────────────────────────────────────
# [OPTIONAL] Maximum size of an artifact downloaded by the runner (bytes).
DOWNLOAD_SIZE_LIMIT_BYTES=52428800

# [OPTIONAL] Maximum cumulative uncompressed size of an extracted archive (bytes).
EXTRACT_SIZE_LIMIT_BYTES=104857600

# [OPTIONAL] Maximum file count in an archive.
EXTRACT_FILE_LIMIT=100

# [OPTIONAL] Inform 7 compile timeout per build.
BUILD_TIMEOUT=5m

# [OPTIONAL] SIGTERM drain budget — total time the server waits for live
# sessions to save and shut down before exiting. `docker compose stop` defaults
# to a 10s SIGKILL deadline; keep this comfortably below that.
SHUTDOWN_DRAIN_TIMEOUT=8s
